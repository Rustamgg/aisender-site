---
import { Icon } from 'astro-icon/components';
---
<header class="sticky top-0 z-50 bg-bg-dark/80 backdrop-blur-md border-b border-white/5">
  <div class="container-tight flex items-center justify-between h-[68px]">
    <a href="/" class="text-xl font-bold text-gradient">AISender</a>

    <nav class="hidden lg:flex items-center gap-8">
      <a href="#features" class="text-[15px] font-medium text-white/90 hover:text-white transition-colors">Возможности</a>
      <a href="#how" class="text-[15px] font-medium text-white/90 hover:text-white transition-colors">Как работает</a>
      <a href="#comparison" class="text-[15px] font-medium text-white/90 hover:text-white transition-colors">Сравнение</a>
      <a href="#pricing" class="text-[15px] font-medium text-white/90 hover:text-white transition-colors">Стоимость услуг</a>
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="https://app.aisender.ru"
        class="hidden md:inline-flex items-center rounded-lg bg-white/10 border border-white/20 px-4 py-2.5 text-sm font-semibold text-white hover:bg-white/15 transition-colors"
      >
        Войти в кабинет
      </a>
      <a
        href="#demo"
        class="hidden sm:inline-flex items-center rounded-lg bg-brand-gradient-h px-4 py-2.5 text-sm font-bold text-white shadow-brand-glow hover:shadow-brand-glow-lg transition-shadow"
      >
        Запросить демо
      </a>
      <button
        type="button"
        id="m-burger"
        class="lg:hidden inline-flex items-center justify-center w-10 h-10 rounded-lg bg-white/10 border border-white/20"
        aria-label="Меню"
      >
        <Icon name="lucide:menu" class="w-[20px] h-[20px] text-white" />
      </button>
    </div>
  </div>

  <div id="m-menu" class="lg:hidden hidden border-t border-white/5 bg-bg-dark">
    <nav class="container-tight flex flex-col py-4 gap-1">
      <a href="#features" class="py-3 text-base text-white/90">Возможности</a>
      <a href="#how" class="py-3 text-base text-white/90">Как работает</a>
      <a href="#comparison" class="py-3 text-base text-white/90">Сравнение</a>
      <a href="#pricing" class="py-3 text-base text-white/90">Стоимость услуг</a>
      <a href="#faq" class="py-3 text-base text-white/90">FAQ</a>
      <a href="https://app.aisender.ru" class="mt-2 inline-flex items-center justify-center rounded-lg bg-white/10 border border-white/20 px-4 py-3 text-base font-semibold text-white">
        Войти в кабинет
      </a>
      <a href="#demo" class="sm:hidden inline-flex items-center justify-center rounded-lg bg-brand-gradient-h px-4 py-3 text-base font-bold text-white shadow-brand-glow">
        Запросить демо
      </a>
    </nav>
  </div>
</header>

<script>
  const burger = document.getElementById('m-burger');
  const menu = document.getElementById('m-menu');
  burger?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => menu?.classList.add('hidden'))
  );
</script>
