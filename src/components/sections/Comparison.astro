---
import { Icon } from 'astro-icon/components';

const cards = [
  { icon: 'lucide:timer', title: 'Время ответа', manualLabel: 'Ручная обработка', manualValue: '5–60 минут', manualBar: 100, aiValue: '3 секунды', aiBar: 4 },
  { icon: 'lucide:bar-chart-3', title: 'Объём диалогов в день', manualLabel: 'Один менеджер', manualValue: '≈ 80', manualBar: 6, aiValue: '10 000+', aiBar: 100 },
  { icon: 'lucide:calendar-clock', title: 'Доступность', manualLabel: 'Рабочие часы', manualValue: '8 часов / день', manualBar: 33, aiValue: '24 / 7 / 365', aiBar: 100 },
  { icon: 'lucide:copy', title: 'Параллельные диалоги', manualLabel: 'Один менеджер ведёт', manualValue: '1 диалог', manualBar: 3, aiValue: 'Без лимита', aiBar: 100 },
];
---
<section id="comparison" class="bg-bg-dark-2 py-16 sm:py-20 lg:py-24">
  <div class="container-tight">
    <div class="text-center mb-10 sm:mb-14">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight">AISender vs ручная обработка</h2>
      <p class="mt-4 text-base sm:text-lg text-white/65 max-w-2xl mx-auto leading-relaxed">
        Четыре параметра, которые меняются после внедрения платформы
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 lg:gap-6">
      {cards.map((c) => (
        <div class="rounded-3xl glass p-6 lg:p-7 flex flex-col gap-5">
          <div class="flex items-center gap-3">
            <Icon name={c.icon} class="w-6 h-6 text-brand-orange" />
            <h3 class="text-xl lg:text-[22px] font-bold text-white">{c.title}</h3>
          </div>
          <div class="flex flex-col gap-2">
            <div class="flex justify-between items-center">
              <span class="text-[13px] text-white/60">{c.manualLabel}</span>
              <span class="text-sm font-bold text-[#999]">{c.manualValue}</span>
            </div>
            <div class="h-2 rounded-full bg-white/10 overflow-hidden">
              <div class="h-full rounded-full bg-[#999]" style={`width:${c.manualBar}%`}></div>
            </div>
          </div>
          <div class="flex flex-col gap-2">
            <div class="flex justify-between items-center">
              <span class="text-[13px] font-semibold text-brand-orange">AISender</span>
              <span class="text-sm font-bold text-white">{c.aiValue}</span>
            </div>
            <div class="h-2 rounded-full bg-white/10 overflow-hidden">
              <div class="h-full rounded-full bg-brand-gradient-h" style={`width:${c.aiBar}%`}></div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
