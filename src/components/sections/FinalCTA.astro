---
import { Icon } from 'astro-icon/components';
---
<section id="demo" class="relative overflow-hidden bg-bg-dark py-16 sm:py-20 lg:py-24">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute top-0 left-1/4 w-[500px] h-[500px] rounded-full bg-brand-orange/30 blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-[600px] h-[600px] rounded-full bg-accent-purple/20 blur-3xl"></div>
  </div>

  <div class="relative container-tight text-center flex flex-col items-center gap-6">
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight max-w-3xl">
      Запустите AI-коммуникации в Telegram
    </h2>
    <p class="text-base sm:text-lg text-white/70 max-w-2xl leading-relaxed">
      Расскажем о возможностях, настроим эмуляцию под ваш бизнес и подберём тариф
    </p>
    <div class="flex flex-wrap justify-center gap-3 mt-2">
      <span class="badge">
        <Icon name="lucide:flask-conical" class="w-4 h-4 text-brand-orange" />
        Эмуляция под ваш бизнес
      </span>
      <span class="badge">
        <Icon name="lucide:zap" class="w-4 h-4 text-brand-orange" />
        Запуск за 5 рабочих дней
      </span>
    </div>
    <div class="mt-4 flex flex-col sm:flex-row items-center gap-4">
      <a href="https://t.me/leonaisupport" class="btn-primary !px-12 !py-4 text-lg">Запросить демо</a>
      <a href="https://t.me/leonaisupport" class="text-base font-medium text-white/70 hover:text-white transition-colors">
        Написать в Telegram
      </a>
    </div>
  </div>
</section>
