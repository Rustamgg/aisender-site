---
const cases = [
  {
    tag: 'Недвижимость',
    title: 'Квалификация клиентов по объектам',
    desc: 'Масштабирование коммуникаций с потенциальными клиентами и квалификация по бюджету и параметрам объекта.',
    metrics: [
      { label: 'Обработано диалогов', value: '1 400+', accent: 'orange' },
      { label: 'Контактов в CRM', value: '29', accent: 'orange' },
      { label: 'Результат', value: 'Назначены показы', accent: 'green' },
    ],
  },
  {
    tag: 'B2B-мероприятия',
    title: 'Регистрация на отраслевую конференцию',
    desc: 'Привлечение проектировщиков на регистрацию через ненавязчивый сценарий вовлечения.',
    metrics: [
      { label: 'Передано контактов', value: '135', accent: 'orange' },
      { label: 'Регистраций', value: '40+', accent: 'orange' },
      { label: 'Конверсия в передачу', value: '26%', accent: 'green' },
    ],
  },
  {
    tag: 'B2B SaaS',
    title: 'Привлечение на демо-вебинар',
    desc: 'Масштабирование канала привлечения целевых пользователей корпоративной ERP-системы на демо.',
    metrics: [
      { label: 'Регистраций на вебинар', value: '23', accent: 'orange' },
      { label: 'Переходов на сайт', value: '111', accent: 'orange' },
      { label: 'Вовлечённость в диалог', value: '66%', accent: 'green' },
    ],
  },
];
---
<section class="bg-bg-light py-16 sm:py-20 lg:py-24">
  <div class="container-tight">
    <div class="text-center mb-10 sm:mb-14">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-ink leading-tight">Результаты клиентов</h2>
      <p class="mt-4 text-base sm:text-lg text-muted-dark max-w-2xl mx-auto leading-relaxed">
        Как компании используют AISender в работе с обращениями
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 lg:gap-6">
      {cases.map((c) => (
        <div class="rounded-2xl bg-white border border-[#E5E5EA] p-6 lg:p-7 shadow-sm flex flex-col gap-4">
          <span class="self-start rounded-md bg-brand-orange/10 px-2.5 py-1 text-xs font-semibold text-brand-orange">{c.tag}</span>
          <h3 class="text-xl font-bold text-ink leading-snug">{c.title}</h3>
          <p class="text-sm text-muted-dark leading-relaxed">{c.desc}</p>
          <div class="border-t border-[#E5E5EA] pt-4 flex flex-col gap-2.5 mt-auto">
            {c.metrics.map((m) => (
              <div class="flex items-center justify-between gap-4">
                <span class="text-[13px] text-muted-dark">{m.label}</span>
                <span class:list={['text-sm font-bold', m.accent === 'orange' ? 'text-brand-orange' : 'text-accent-green']}>{m.value}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Quote -->
    <div class="mt-8 lg:mt-10 rounded-2xl bg-white border border-brand-orange/20 px-6 sm:px-8 py-5 sm:py-6 flex items-start gap-4 sm:gap-5 relative overflow-hidden">
      <span class="absolute left-0 top-1/2 -translate-y-1/2 block w-1 h-20 bg-brand-orange rounded-r-md"></span>
      <img src="/avatar-realestate.png" alt="" width="56" height="56" class="rounded-full object-cover shrink-0 w-12 h-12 sm:w-14 sm:h-14" />
      <div class="flex flex-col gap-2">
        <p class="text-[15px] sm:text-base text-[#333] italic leading-relaxed">
          «Люди понимают и квалятся, вижу даже одну сделку, где назначен показ. Лиды целевые.»
        </p>
        <span class="text-sm font-semibold text-muted-dark">Директор по продажам, агентство элитной недвижимости</span>
      </div>
    </div>
  </div>
</section>
