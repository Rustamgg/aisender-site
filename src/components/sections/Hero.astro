---
import { Icon } from 'astro-icon/components';
---
<section class="relative overflow-hidden bg-bg-dark">
  <!-- Decorative orbs -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="absolute -top-24 -right-32 w-[500px] h-[500px] rounded-full bg-brand-orange/30 blur-3xl"></div>
    <div class="absolute top-1/2 -left-40 w-[600px] h-[600px] rounded-full bg-accent-purple/20 blur-3xl"></div>
    <div class="absolute bottom-0 left-1/3 w-[400px] h-[400px] rounded-full bg-brand-orange-light/20 blur-3xl"></div>
  </div>

  <div class="relative container-tight pt-12 sm:pt-16 lg:pt-20 pb-12 lg:pb-16">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_440px] xl:grid-cols-[1fr_520px] 2xl:grid-cols-[1fr_580px] gap-10 lg:gap-14 items-start">
      <!-- LEFT -->
      <div class="flex flex-col gap-7">
        <h1 class="font-extrabold tracking-tight leading-[1.05] text-[40px] sm:text-[52px] lg:text-[64px]">
          <span class="block text-white">AI-платформа</span>
          <span class="block text-gradient">для коммуникаций</span>
          <span class="block text-white">в Telegram</span>
        </h1>

        <p class="text-base sm:text-lg text-white/70 leading-relaxed max-w-[560px]">
          Автоматизация диалогов с клиентами, квалификация обращений и интеграция с CRM. Перед запуском настраиваем AI на тестовом полигоне под ваш бизнес — вы видите работу до старта.
        </p>

        <div class="flex items-center gap-2.5 text-sm font-medium text-white/70">
          <span class="block w-2 h-2 rounded-full bg-accent-green animate-pulse-dot"></span>
          Более 1 200 компаний используют платформу
        </div>

        <div class="flex flex-col sm:flex-row gap-3 sm:items-center">
          <a href="#demo" class="btn-primary">Запросить демо</a>
          <a href="#emulation" class="text-base font-semibold text-brand-orange hover:text-brand-orange-light transition-colors px-2">
            Демо под ваш бизнес →
          </a>
        </div>

        <div class="flex flex-wrap gap-2.5">
          <span class="badge">
            <Icon name="lucide:flask-conical" class="w-4 h-4 text-brand-orange" />
            Эмуляция под ваш бизнес
          </span>
          <span class="badge">
            <Icon name="lucide:zap" class="w-4 h-4 text-brand-orange" />
            Запуск за 5 дней
          </span>
        </div>
      </div>

      <!-- RIGHT — Dashboard -->
      <div class="relative">
        <!-- Floating tile: Эмуляция активна -->
        <div class="absolute -top-3 -left-3 sm:-left-8 z-10 inline-flex items-center gap-2 rounded-full bg-brand-gradient-h px-4 py-2.5 shadow-brand-glow">
          <Icon name="lucide:flask-conical" class="w-4 h-4 text-white" />
          <span class="text-[13px] font-bold text-white">Эмуляция активна</span>
        </div>
        <!-- Floating tile: 3 sec -->
        <div class="hidden sm:flex absolute -bottom-4 -left-6 z-10 items-center gap-3 rounded-2xl bg-[#1A1A24] border border-white/10 px-4 py-3 shadow-xl">
          <Icon name="lucide:zap" class="w-5 h-5 text-brand-orange" />
          <div class="flex flex-col leading-none">
            <span class="text-sm font-extrabold text-white">3 сек</span>
            <span class="text-[10px] text-white/60 mt-0.5">среднее время ответа</span>
          </div>
        </div>
        <!-- Floating tile: integrations -->
        <div class="absolute -bottom-3 -right-2 sm:-right-6 z-10 inline-flex items-center gap-2 rounded-xl bg-[#1A1A24] border border-white/10 px-3 py-2.5">
          <Icon name="lucide:plug" class="w-3.5 h-3.5 text-brand-orange" />
          <span class="text-[11px] font-semibold text-white">Bitrix · Amo · API</span>
        </div>

        <!-- Dashboard card -->
        <div class="relative rounded-3xl bg-[#1A1A24] border-2 border-white/10 overflow-hidden shadow-2xl shadow-brand-orange/10">
          <!-- Header -->
          <div class="flex items-center justify-between bg-[#2A2A38] px-5 py-3.5">
            <div class="flex items-center gap-2.5">
              <span class="block w-2.5 h-2.5 rounded-full bg-brand-gradient"></span>
              <span class="text-sm font-bold text-white">AISender Platform</span>
            </div>
            <span class="inline-flex items-center gap-1.5 rounded-md border border-accent-green bg-accent-green/20 px-2 py-0.5 text-[10px] font-bold tracking-widest text-accent-green">
              <span class="block w-1.5 h-1.5 rounded-full bg-accent-green animate-pulse-dot"></span>
              LIVE
            </span>
          </div>

          <!-- Body -->
          <div class="flex flex-col gap-6 p-6">
            <!-- Metric -->
            <div class="flex flex-col gap-2">
              <div class="flex items-center justify-between">
                <span class="text-xs uppercase tracking-wider text-white/60">Контакты сегодня</span>
                <span class="inline-flex items-center gap-1 rounded-md bg-accent-green/20 px-2 py-0.5">
                  <Icon name="lucide:trending-up" class="w-3 h-3 text-accent-green" />
                  <span class="text-[11px] font-bold text-accent-green">+18%</span>
                </span>
              </div>
              <div class="flex items-end gap-2">
                <span class="text-5xl font-extrabold text-gradient leading-none">1 247</span>
                <span class="text-xs text-white/50 mb-1">из 3 000 в тарифе</span>
              </div>
              <div class="h-1.5 rounded-full bg-white/10 overflow-hidden">
                <div class="h-full w-[42%] bg-brand-gradient-h"></div>
              </div>
            </div>

            <!-- Bar chart -->
            <div class="flex flex-col gap-3">
              <div class="flex items-center justify-between">
                <span class="text-xs uppercase tracking-wider text-white/60">Активность по часам</span>
                <span class="text-[11px] font-bold text-brand-orange">24 / 7</span>
              </div>
              <div class="flex items-end gap-1.5 h-[90px]">
                {[18, 14, 32, 54, 80, 74, 88, 62, 46, 38, 24, 16].map((h, i) => (
                  <div
                    class:list={[
                      'flex-1 rounded-t-md',
                      i >= 4 && i <= 7 ? 'bg-brand-gradient' : i >= 3 && i <= 8 ? 'bg-brand-orange-light/60' : 'bg-brand-orange-light/30',
                    ]}
                    style={`height:${h}px`}
                  ></div>
                ))}
              </div>
              <div class="flex justify-between text-[10px] text-white/40">
                <span>00</span><span>06</span><span>12</span><span>18</span><span>23</span>
              </div>
            </div>

            <!-- Agents -->
            <div class="flex flex-col gap-3">
              <div class="flex items-center justify-between">
                <span class="text-xs uppercase tracking-wider text-white/60">AI-агенты в работе</span>
                <span class="text-[11px] font-bold text-accent-green">3 онлайн</span>
              </div>
              <div class="flex flex-col gap-2">
                {[
                  { color: 'from-[#FF6A00] to-[#FF9500]', name: 'Агентство недвижимости', count: 47 },
                  { color: 'from-[#7C3AED] to-[#A855F7]', name: 'EdTech-проект', count: 23 },
                  { color: 'from-[#22C55E] to-[#16A34A]', name: 'B2B SaaS — ERP', count: 18 },
                ].map((a) => (
                  <div class="flex items-center gap-3 rounded-xl bg-white/[0.04] px-3 py-2.5">
                    <span class:list={['block w-7 h-7 rounded-full bg-gradient-to-br', a.color]}></span>
                    <div class="flex-1 min-w-0">
                      <div class="text-xs font-semibold text-white truncate">{a.name}</div>
                      <div class="text-[10px] text-white/50">Активных диалогов: {a.count}</div>
                    </div>
                    <span class="block w-2 h-2 rounded-full bg-accent-green"></span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats Bar -->
    <div class="mt-12 lg:mt-14 mx-auto max-w-3xl rounded-2xl bg-white/[0.04] border border-white/10 backdrop-blur-md py-5 px-3 sm:px-12 flex items-center justify-between">
      <div class="flex flex-col items-center gap-1 flex-1 min-w-0">
        <span class="text-xl sm:text-3xl font-extrabold text-gradient whitespace-nowrap">1 200+</span>
        <span class="text-[11px] sm:text-xs text-white/60 tracking-wide">компаний</span>
      </div>
      <span class="block w-px h-10 bg-white/15 shrink-0"></span>
      <div class="flex flex-col items-center gap-1 flex-1 min-w-0">
        <span class="text-xl sm:text-3xl font-extrabold text-gradient whitespace-nowrap">30 000+</span>
        <span class="text-[11px] sm:text-xs text-white/60 tracking-wide text-center">диалогов в сутки</span>
      </div>
      <span class="block w-px h-10 bg-white/15 shrink-0"></span>
      <div class="flex flex-col items-center gap-1 flex-1 min-w-0">
        <span class="text-xl sm:text-3xl font-extrabold text-gradient whitespace-nowrap">5 дней</span>
        <span class="text-[11px] sm:text-xs text-white/60 tracking-wide text-center">средний срок запуска</span>
      </div>
    </div>
  </div>
</section>
