---
import { Icon } from 'astro-icon/components';

const steps = [
  { icon: 'lucide:clipboard-list', title: 'Бриф\nи настройка', desc: 'Заполняете бриф: цели, тональность, сценарии. Команда настраивает AI под бренд.' },
  { icon: 'lucide:flask-conical', title: 'Эмуляция\nдиалогов', desc: 'Тестируете агента до запуска. Видите поведение в реальных сценариях.' },
  { icon: 'lucide:zap', title: 'Запуск\nкоммуникаций', desc: 'AI-агент обрабатывает диалоги в Telegram по сегменту в режиме 24/7.' },
  { icon: 'lucide:database', title: 'Передача\nв CRM', desc: 'Квалифицированные контакты автоматически попадают в CRM с историей.' },
];
---
<section id="how" class="bg-bg-light py-16 sm:py-20 lg:py-24">
  <div class="container-tight">
    <div class="text-center mb-10 sm:mb-14">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-ink leading-tight">Как это работает</h2>
      <p class="mt-4 text-base sm:text-lg text-muted-dark max-w-2xl mx-auto leading-relaxed">
        Четыре шага от настройки до передачи квалифицированного контакта в CRM
      </p>
    </div>

    <div class="flex flex-col gap-4 sm:grid sm:grid-cols-2 sm:gap-5 lg:grid-cols-4 lg:gap-6 relative">
      {steps.map((s, i) => (
        <div class="relative flex flex-row sm:flex-col items-start sm:items-center text-left sm:text-center gap-4 sm:gap-3 sm:px-2 rounded-2xl sm:rounded-none bg-white sm:bg-transparent border border-[#E0E0E5] sm:border-0 p-5 sm:p-0 shadow-sm sm:shadow-none">
          <div class="relative shrink-0">
            <div class="w-14 h-14 sm:w-20 sm:h-20 rounded-full bg-brand-gradient shadow-brand-glow flex items-center justify-center">
              <Icon name={s.icon} class="w-6 h-6 sm:w-9 sm:h-9 text-white" />
            </div>
            {i < steps.length - 1 && (
              <Icon name="lucide:arrow-right" class="hidden lg:block absolute top-1/2 left-full -translate-y-1/2 ml-6 w-8 h-8 text-brand-orange/60" />
            )}
          </div>
          <div class="flex flex-col gap-1 sm:gap-3 sm:items-center min-w-0">
            <span class="text-[11px] sm:text-xs font-bold tracking-widest text-brand-orange uppercase">Шаг {i + 1}</span>
            <h3 class="text-base sm:text-lg font-bold text-ink leading-tight sm:whitespace-pre-line">{s.title}</h3>
            <p class="text-sm text-muted-dark leading-relaxed sm:max-w-[260px]">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-10 flex justify-center">
      <a href="#demo" class="btn-primary !text-ink !bg-brand-gradient-h !text-white">Запросить демо</a>
    </div>
  </div>
</section>
