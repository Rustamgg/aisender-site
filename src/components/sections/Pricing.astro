---
const tariffs = [
  {
    name: 'Старт',
    price: '60 000 ₽',
    period: 'в месяц',
    volume: '3 000 контактов в месяц',
    features: ['1 AI-агент', 'Интеграция с CRM', 'Эмуляция перед запуском', 'Личный менеджер', 'Базовая аналитика'],
    cta: 'Запросить демо',
    highlight: false,
  },
  {
    name: 'Бизнес',
    price: '90 000 ₽',
    period: 'в месяц',
    volume: '6 000 контактов в месяц',
    features: ['2 AI-агента', 'Отдельная инфраструктура', 'Расширенная аналитика', 'Всё из «Старт»'],
    cta: 'Запросить демо',
    highlight: true,
  },
  {
    name: 'Корпоративный',
    price: '120 000 ₽',
    period: 'в месяц',
    volume: '10 000 контактов в месяц',
    features: ['Без ограничений на агентов', 'Кастомная воронка', 'Приоритетная поддержка', 'Всё из «Бизнес»'],
    cta: 'Запросить демо',
    highlight: false,
  },
  {
    name: 'Индивидуальный',
    price: 'По запросу',
    period: 'договорная',
    volume: 'От 10 000 контактов',
    features: ['Выделенная инфраструктура', 'Кастомные интеграции', 'Команда поддержки'],
    cta: 'Связаться',
    highlight: false,
  },
];
---
<section id="pricing" class="bg-bg-dark-2 py-16 sm:py-20 lg:py-24">
  <div class="container-tight">
    <div class="text-center mb-10 sm:mb-14">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight">Тарифы</h2>
      <p class="mt-4 text-base sm:text-lg text-white/65 max-w-3xl mx-auto leading-relaxed">
        Тариф включает количество контактов в месяц. Дальше — встроенная воронка с квалификацией и передачей в CRM.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
      {tariffs.map((t) => (
        <div
          class:list={[
            'relative rounded-3xl p-7 lg:p-8 flex flex-col gap-5',
            t.highlight
              ? 'bg-brand-orange/10 border-2 border-brand-orange shadow-brand-glow'
              : 'glass',
          ]}
        >
          {t.highlight && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-md bg-brand-orange px-3 py-1 text-[11px] font-bold tracking-widest text-white">
              РЕКОМЕНДУЕМ
            </span>
          )}
          <div>
            <h3 class="text-lg font-bold text-white">{t.name}</h3>
            <div class="mt-3 flex items-baseline gap-x-2 gap-y-1 flex-wrap">
              <span class:list={['text-3xl lg:text-[34px] font-extrabold whitespace-nowrap', t.highlight ? 'text-brand-orange' : 'text-white']}>{t.price}</span>
              <span class="text-sm text-white/55">{t.period}</span>
            </div>
            <p class="mt-3 text-[13px] font-semibold text-brand-orange">{t.volume}</p>
          </div>
          <ul class="flex flex-col gap-2.5 border-t border-white/10 pt-4 grow">
            {t.features.map((f) => (
              <li class="flex items-center gap-2.5 text-[13px] text-white">
                <span class="text-accent-green font-bold">✓</span>
                {f}
              </li>
            ))}
          </ul>
          <a
            href="#demo"
            class:list={[
              'inline-flex justify-center items-center rounded-xl py-3 text-sm font-bold transition-all',
              t.highlight
                ? 'bg-brand-gradient-h text-white shadow-brand-glow hover:shadow-brand-glow-lg'
                : 'bg-white/10 border border-brand-orange text-white hover:bg-white/15',
            ]}
          >
            {t.cta}
          </a>
        </div>
      ))}
    </div>
    <p class="mt-8 text-center text-sm text-white/55 max-w-3xl mx-auto leading-relaxed">
      Контакт = один инициированный диалог с потенциальным клиентом. Дальнейшая работа платформы — ответы, квалификация, прогрев и передача в CRM — уже включены в стоимость тарифа. Минимальный срок подключения — 1 месяц.
    </p>
  </div>
</section>
